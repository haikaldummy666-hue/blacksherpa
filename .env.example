# Vercel + Supabase Production Environment Variables

# Supabase Connection (Transaction Mode for pooled connections)
# e.g., postgresql://postgres.xxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.nnqxfvtgnbxcoonavouf.supabase.co:5432/postgres?pgbouncer=true"

# Supabase Direct Connection (Session Mode for migrations)
# e.g., postgresql://postgres.xxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://postgres:[YOUR_PASSWORD]@db.nnqxfvtgnbxcoonavouf.supabase.co:5432/postgres"

# Supabase Public Keys (Used by client-side Supabase SDK)
NEXT_PUBLIC_SUPABASE_URL="https://nnqxfvtgnbxcoonavouf.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_yIBkSL-MhHTsld2ElSapqw_-grFksq6"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_yIBkSL-MhHTsld2ElSapqw_-grFksq6"

# Supabase Service Role Key (Used for server-side administrative tasks)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# NextAuth v5 Configuration
