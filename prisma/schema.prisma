generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Use connection pooling for serverless (Vercel)
  // DATABASE_URL should point to your pooled connection (e.g., Supabase transaction mode)
  url       = env("DATABASE_URL")
  // directUrl should point to the direct connection (e.g., Supabase session mode)
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN_PRODUKSI
  PIC_POTONG_GUDANG
  PIC_PRODUKSI
  PIC_QC
  PIC_SEAL
  PIC_PENGIRIMAN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(PIC_PRODUKSI)
  division      String?
  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]
  tasks         Task[]    @relation("AssignedTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  category    String
  bom         BOM[]
  jobOrders   JobOrder[]
  routing     String[] // e.g., ["POTONG", "PRODUKSI", "QC", "SEAL", "SHIPPING"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Material {
  id            String   @id @default(cuid())
  name          String
  unit          String
  stock         Float    @default(0)
  minStock      Float    @default(0)
  pricePerUnit  Float    @default(0)
  bomItems      BOM[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BOM {
  id          String   @id @default(cuid())
  productId   String
  materialId  String
  qtyPerUnit  Float
  unit        String

  product     Product  @relation(fields: [productId], references: [id])
  material    Material @relation(fields: [materialId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum JobStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model JobOrder {
  id                String    @id @default(cuid())
  productId         String
  productName       String
  qty               Int
  status            JobStatus @default(DRAFT)
  priority          Priority  @default(MEDIUM)
  progress          Float     @default(0)
  wipPhase          String?
  plannedStart      DateTime?
  plannedEnd        DateTime?
  actualStart       DateTime?
  actualEnd         DateTime?
  
  product           Product   @relation(fields: [productId], references: [id])
  tasks             Task[]
  wipLogs           WIPLog[]
  auditLogs         AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  REWORK
}

model Task {
  id          String     @id @default(cuid())
  jobId       String
  phase       String     // e.g., "POTONG", "PRODUKSI", "QC"
  status      TaskStatus @default(PENDING)
  assignedTo  String?
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?    @db.Text
  photoUrl    String?

  job         JobOrder   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user        User?      @relation("AssignedTasks", fields: [assignedTo], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WIPLog {
  id          String   @id @default(cuid())
  jobId       String
  phase       String
  percentage  Float
  notes       String?
  
  job         JobOrder @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  jobId       String?
  action      String
  details     String?  @db.Text
  ipAddress   String?
  userAgent   String?

  user        User?     @relation(fields: [userId], references: [id])
  job         JobOrder? @relation(fields: [jobId], references: [id])

  createdAt DateTime @default(now())
}
